# AuraCart Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=auracart_db

# Railway MySQL (when deployed - replace with actual Railway credentials)
# DATABASE_URL=mysql://user:password@host:port/dbname

# WhatsApp Notification (Forwarding checkout to WA)
# Nomor WA Owner/Admin (format: 628xxxxxxxxxx)
WA_OWNER_NUMBER=6281234567890

# Admin Credentials (for login)
ADMIN_EMAIL=admin@auracart.com
ADMIN_PASSWORD=123456
